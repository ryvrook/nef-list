{
  "name": "nef-list",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create nef-list",
    "db:migrate": "wrangler d1 migrations apply nef-list --remote",
    "db:migrate:local": "wrangler d1 migrations apply nef-list --local"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
